# ============================================================
# Podwrite.ai — 환경변수 예시
# 이 파일을 .env.local 로 복사 후 실제 값을 채워주세요.
# .env.local 은 절대 git에 커밋하지 마세요.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── Claude API ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Perplexity Sonar API ────────────────────────────────────
PERPLEXITY_API_KEY=pplx-...

# ── 맞춤법 API (CLOVA Spell Checker) ─────────────────────────
# 나라인포테크 계약 완료 시 아래 주석 해제
# NARAINFO_SPELL_API_KEY=YOUR_NARAINFO_KEY
# CLOVA_SPELL_CLIENT_ID=YOUR_CLOVA_CLIENT_ID
# CLOVA_SPELL_CLIENT_SECRET=YOUR_CLOVA_CLIENT_SECRET

# ── 토스페이먼츠 ─────────────────────────────────────────────
TOSS_PAYMENTS_SECRET_KEY=test_sk_...
TOSS_PAYMENTS_CLIENT_KEY=test_ck_...
# 웹훅 서명 검증용 (토스 대시보드에서 설정)
TOSS_PAYMENTS_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ── Upstash Redis (Rate Limiting) ────────────────────────────
UPSTASH_REDIS_REST_URL=https://YOUR_UPSTASH_URL.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# ── Resend (이메일) ──────────────────────────────────────────
SECRET_RESEND_API_KEY=re_...
# Supabase Auth 웹훅 시크릿 (Supabase 대시보드 > Database > Webhooks에서 설정)
SUPABASE_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ── Inngest ──────────────────────────────────────────────────
INNGEST_EVENT_KEY=YOUR_INNGEST_EVENT_KEY
INNGEST_SIGNING_KEY=YOUR_INNGEST_SIGNING_KEY

# ── Sentry ───────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=YOUR_SENTRY_ORG
SENTRY_PROJECT=podwrite-ai

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# production: https://podwrite.ai
