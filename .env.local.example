# ============================================================
# Podwrite.ai — 환경변수 예시
# 이 파일을 .env.local 로 복사 후 실제 값을 채워주세요.
# .env.local 은 절대 git에 커밋하지 마세요.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Supabase Auth 웹훅 시크릿 (Supabase 대시보드 > Database > Webhooks에서 설정)
SUPABASE_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ── Claude API (Anthropic) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Perplexity Sonar API ─────────────────────────────────────
PERPLEXITY_API_KEY=pplx-...

# ── 맞춤법 API (CLOVA Spell Checker / 나라인포테크) ────────────
# CLOVA Spell Checker (Naver Cloud Platform) 사용 시:
# CLOVA_SPELL_API_URL=https://naveropenapi.apigw.ntruss.com/v1/api-gate/grammar-checker
# CLOVA_API_KEY_ID=YOUR_NCP_API_KEY_ID
# CLOVA_API_KEY=YOUR_NCP_API_KEY
# 나라인포테크 계약 완료 시 위 URL·키를 나라인포테크 값으로 교체

# ── 토스페이먼츠 ─────────────────────────────────────────────
# 시크릿 키 (서버 전용 — 절대 클라이언트에 노출 금지)
SECRET_TOSS_SECRET_KEY=test_sk_...
# 클라이언트 키 (브라우저에서 결제창 호출용)
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...

# ── Upstash Redis (Rate Limiting) ────────────────────────────
UPSTASH_REDIS_REST_URL=https://YOUR_UPSTASH_URL.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# ── Resend (이메일) ──────────────────────────────────────────
SECRET_RESEND_API_KEY=re_...

# ── Inngest (백그라운드 잡) ──────────────────────────────────
INNGEST_EVENT_KEY=YOUR_INNGEST_EVENT_KEY
SECRET_INNGEST_SIGNING_KEY=YOUR_INNGEST_SIGNING_KEY

# ── Sentry (에러 추적) ───────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=YOUR_SENTRY_ORG
SENTRY_PROJECT=podwrite-ai

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# production: https://podwrite.ai
