{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "functions": {
    "app/api/diagnostics/route.ts": {
      "maxDuration": 60
    },
    "app/api/chat/ai/route.ts": {
      "maxDuration": 60
    },
    "app/api/generate-docx/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/generate-epub/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/translate/route.ts": {
      "maxDuration": 300,
      "memory": 512
    },
    "app/api/inngest/route.ts": {
      "maxDuration": 300,
      "memory": 512
    },
    "app/api/kdp/package/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/kdp/metadata/route.ts": {
      "maxDuration": 30,
      "memory": 256
    },
    "app/api/subscriptions/webhook/route.ts": {
      "maxDuration": 30,
      "memory": 256
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
